{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/ai/analyze",
      "destination": "/api/ai/analyze.ts"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
